# Required — copy the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'production' on Render (enables SSL for DB)
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Alpha testing mode ────────────────────────────────────────────────────────
TESTING=false

# ── Admin secret (production) ─────────────────────────────────────────────────
ADMIN_SECRET=change_me_to_something_random

# Bug report email (uses Resend API — free at resend.com)
RESEND_API_KEY=re_your_api_key_here
BUG_REPORT_TO=your@email.com
BUG_REPORT_FROM=bugs@yourdomain.com
