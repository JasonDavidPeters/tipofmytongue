# Required — copy the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'production' on Render (enables SSL for DB)
NODE_ENV=production

# ── Alpha testing mode ────────────────────────────────────────────────────────
# Set to 'true' to enable testing mode:
#   - Songs table is WIPED on every server restart
#   - /api/admin/reset endpoint clears DB and re-seeds (no secret needed)
#   - A red warning banner appears on the frontend
# Set to 'false' or remove entirely for production use.
TESTING=false

# ── Admin secret (production) ─────────────────────────────────────────────────
# Protects /api/admin/ingest in production (ignored when TESTING=true)
ADMIN_SECRET=change_me_to_something_random
