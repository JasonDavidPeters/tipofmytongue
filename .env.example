# Required — copy the Internal Database URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to 'production' on Render (enables SSL for DB)
NODE_ENV=production

# Optional — protects the /api/admin/ingest endpoint
# If not set, the endpoint is open (fine for private use)
ADMIN_SECRET=change_me_to_something_random
